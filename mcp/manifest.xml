<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="TaskPaneApp">
    <Id>6f8a3c2e-9b4d-4f1a-8e7c-d2b5a6f3e801</Id>
    <Version>1.0.0</Version>
    <ProviderName>word-mcp</ProviderName>
    <DefaultLocale>en-US</DefaultLocale>
    <DisplayName DefaultValue="Track Changes Agent" />
    <Description DefaultValue="Applies AI-suggested track changes from the MCP server live in Word." />
    <IconUrl DefaultValue="https://placehold.co/32x32.png" />
    <HighResolutionIconUrl DefaultValue="https://placehold.co/64x64.png" />
    <SupportUrl DefaultValue="https://recreation-shore-scheme-calendar.trycloudflare.com" />
    <AppDomains>
        <AppDomain>https://recreation-shore-scheme-calendar.trycloudflare.com</AppDomain>
    </AppDomains>
    <Hosts>
        <Host Name="Document" />
    </Hosts>
    <Requirements>
        <Sets>
            <Set Name="WordApi" MinVersion="1.4" />
        </Sets>
    </Requirements>
    <DefaultSettings>
        <SourceLocation DefaultValue="https://recreation-shore-scheme-calendar.trycloudflare.com/addin/taskpane" />
    </DefaultSettings>
    <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
